{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "./AGENTS.md"
    ],
    "plugin": [
        "~/.config/opencode/plugins/engram.ts"
    ],
    "lsp": {
        "sol-lsp": {
            "command": [
                "nomicfoundation-solidity-language-server",
                "--stdio"
            ],
            "extensions": [
                ".sol"
            ]
        }
    },
    "provider": {
        "openrouter": {
            "models": {
                "moonshotai/kimi-k2.5": {
                    "options": {
                        "provider": {
                            "only": [
                                "moonshotai"
                            ]
                        }
                    }
                },
                "qwen/qwen3-coder": {
                    "options": {
                        "provider": {
                            "only": [
                                "chutes/fp8"
                            ]
                        }
                    }
                },
                "minimax/minimax-m2.1": {
                    "options": {
                        "temperature": 0.5,
                        "provider": {
                            "only": [
                                "atlas-cloud/fp8"
                            ]
                        }
                    }
                },
                "z-ai/glm-4.7": {
                    "options": {
                        "temperature": 0.35,
                        "provider": {
                            "only": [
                                "parasail/fp8"
                            ]
                        }
                    }
                },
                "x-ai/grok-4.1-fast": {
                    "options": {
                        "temperature": 0.45,
                        "reasoning": {
                            "effort": "high"
                        }
                    }
                },
                "google/gemini-3-flash-preview": {
                    "options": {
                        "temperature": 0.5,
                        "reasoning": {
                            "effort": "medium"
                        }
                    }
                }
            }
        },
        "anthropic": {
            "models": {
                "claude-sonnet-4-5": {
                    "options": {
                        "temperature": 0.35,
                        "textVerbosity": "low",
                        "reasoningEffort": "high"
                    }
                }
            }
        }
    },
    "agent": {
        "build": {
            "temperature": 0.35,
            "prompt": "Orchestration agent. Classify requests and dispatch agent chains per AGENTS.md. Do not write code, research, or design.\n\nDo not read source files before dispatching. Classify from request text and context nodes only.\n\nCONTEXT PASSING: Pass context inline in task descriptions — the full information each subagent needs. Read the task return value and pass relevant parts forward to the next phase. Subagents do not write to engram.\n\nBATCHING: For multi-task workloads, group by shared file ownership, then subsystem, respect dependency order, verification last. Batch size 2-3. State batches and rationale before dispatching. Dispatch independent batches in parallel.",
            "permission": {
                "task": {
                    "*": "allow",
                    "explore": "deny"
                }
            }
        },
        "qa-reviewer": {
            "description": "Post-implementation code review. Reads changed files against the original task spec and returns a structured verdict: PASS, NEEDS_FIX, or BLOCK. Never modifies files. Always run after deterministic-coder completes a task.",
            "mode": "subagent",
            "model": "anthropic/claude-sonnet-4-5",
            "temperature": 0.2,
            "steps": 15,
            "color": "#e67e22",
            "tools": {
                "save_context": false,
                "update_context": false,
                "resolve_context": false,
                "link_context": false,
                "delete_context": false,
                "move_context": false,
                "rename_context": false,
                "rebuild_fts": false,
                "stale_context": false
            },
            "permission": {
                "edit": "deny",
                "bash": "deny",
                "webfetch": "deny"
            }
        },
        "deterministic-coder": {
            "description": "Bug fixes, spec implementations, refactoring, and routine development. Use when the correct solution is well-defined and consistency matters more than exploration.",
            "mode": "subagent",
            "model": "anthropic/claude-haiku-4-5",
            "temperature": 0.15,
            "steps": 30,
            "color": "#4a90d9",
            "tools": {
                "save_context": false,
                "update_context": false,
                "resolve_context": false,
                "link_context": false,
                "delete_context": false,
                "move_context": false,
                "rename_context": false,
                "rebuild_fts": false,
                "stale_context": false
            },
            "permission": {
                "edit": "allow",
                "bash": "allow",
                "webfetch": "deny"
            }
        },
        "exploratory-architect": {
            "description": "Architecture design, algorithm optimization, and complex problem-solving. Use when multiple valid solutions exist, trade-offs need evaluation, or requirements are ambiguous.",
            "mode": "subagent",
            "temperature": 0.6,
            "steps": 15,
            "color": "#9b59b6",
            "thinking": {
                "type": "enabled",
                "budgetTokens": 10000
            },
            "tools": {
                "save_context": false,
                "update_context": false,
                "resolve_context": false,
                "link_context": false,
                "delete_context": false,
                "move_context": false,
                "rename_context": false,
                "rebuild_fts": false,
                "stale_context": false
            },
            "permission": {
                "edit": "deny",
                "bash": "deny",
                "webfetch": "allow"
            }
        },
        "expert-researcher": {
            "description": "Evidence gathering, source evaluation, and synthesis. Use when investigating unfamiliar topics, verifying claims, comparing solutions, or when confidence in an answer is below high.",
            "mode": "subagent",
            "temperature": 0.35,
            "steps": 20,
            "color": "#27ae60",
            "thinking": {
                "type": "enabled",
                "budgetTokens": 5000
            },
            "tools": {
                "save_context": false,
                "update_context": false,
                "resolve_context": false,
                "link_context": false,
                "delete_context": false,
                "move_context": false,
                "rename_context": false,
                "rebuild_fts": false,
                "stale_context": false
            },
            "permission": {
                "edit": "deny",
                "bash": "deny",
                "webfetch": "allow"
            }
        }
    },
    "command": {
        "dispatch-todos": {
            "description": "Group and dispatch all open todos to deterministic-coder in parallel batches",
            "template": "Read the current todo list. Apply the grouping methodology: cluster by shared file ownership first, logical subsystem second, respect dependency order, put verification tasks last. State the proposed batches and rationale before dispatching. Then dispatch each independent batch in parallel using simultaneous task tool calls. Evaluate results after each wave before proceeding to the next.",
            "agent": "build"
        }
    }
}
